<UserControl x:Class="Hull.Gui.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:Hull.Gui">
    <DockPanel Margin="24,14,24,20">
        <!-- header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18" Height="34">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Dashboard" Style="{StaticResource ScreenTitle}" />
                <TextBlock x:Name="Sub" Style="{StaticResource Muted}" Margin="14,9,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,112,0" VerticalAlignment="Center">
                <Button Style="{StaticResource Btn}" Click="OnStopAll">
                    <StackPanel Orientation="Horizontal">
                        <h:Icon Glyph="stop" Width="13" Height="13" Brush="{StaticResource Text}" VerticalAlignment="Center" />
                        <TextBlock Text="Stop all sites" Margin="7,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Click="OnStartAll">
                    <StackPanel Orientation="Horizontal">
                        <h:Icon Glyph="play" Width="13" Height="13" Brush="{StaticResource TextOnAccent}" VerticalAlignment="Center" />
                        <TextBlock Text="Start all sites" Margin="7,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- metric tiles -->
                <UniformGrid Rows="1" Margin="0,0,0,4">
                    <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="Sites running" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="TileSites" Text="–" FontSize="27" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                        <StackPanel>
                            <TextBlock Text="Services running" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="TileServices" Text="–" FontSize="27" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                        <StackPanel>
                            <TextBlock Text="Issues" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="TileIssues" Text="–" FontSize="27" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Shared services" Style="{StaticResource Muted}" />
                            <TextBlock x:Name="TileShared" Text="–" FontSize="27" FontWeight="SemiBold" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- two columns: recent sites / active services -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Recent sites" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="6,4">
                            <ItemsControl x:Name="RecentList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Cursor="Hand" MouseLeftButtonUp="OnRecentRowClick">
                                        <Grid Margin="6,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource TextFaint}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding running}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource Green}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1" Text="{Binding name}" VerticalAlignment="Center" />
                                            <Border Grid.Column="2" Style="{StaticResource Chip}" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding DisplayKind}" Foreground="{DynamicResource TextDim}" FontSize="11" />
                                            </Border>
                                            <Button Grid.Column="3" Style="{StaticResource BtnSm}" Click="OnStartSite"
                                                    Content="Start" Visibility="{Binding NotRunning, Converter={StaticResource B2V}}" />
                                            <Button Grid.Column="3" Style="{StaticResource IconBtn}" Click="OnOpenSite" ToolTip="Open"
                                                    Visibility="{Binding running, Converter={StaticResource B2V}}">
                                                <h:Icon Glyph="external" Width="15" Height="15" Brush="{DynamicResource TextDim}" />
                                            </Button>
                                        </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Active services" Style="{StaticResource SectionLabel}" />
                        <Border Style="{StaticResource Card}" Padding="6,4">
                            <Grid>
                                <TextBlock x:Name="NoServices" Text="No shared services yet." Style="{StaticResource Faint}"
                                           Margin="8,8" Visibility="Collapsed" />
                                <ItemsControl x:Name="ActiveList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <h:Icon Grid.Column="0" Glyph="{Binding Glyph}" Width="16" Height="16"
                                                        Brush="{DynamicResource TextDim}" VerticalAlignment="Center" Margin="2,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="{Binding name}" VerticalAlignment="Center" />
                                                <Border Grid.Column="2" Style="{StaticResource Chip}" Margin="0,0,8,0"
                                                        Visibility="{Binding HasPort, Converter={StaticResource B2V}}">
                                                    <TextBlock Text="{Binding Endpoint}" FontFamily="{StaticResource FontMono}" FontSize="11"
                                                               Foreground="{DynamicResource TextDim}" />
                                                </Border>
                                                <Button Grid.Column="3" Style="{StaticResource BtnSm}" Click="OnStartService"
                                                        Content="Start" Visibility="{Binding NotRunning, Converter={StaticResource B2V}}" />
                                                <Button Grid.Column="3" Style="{StaticResource BtnSm}" Click="OnStopService"
                                                        Content="Stop" Visibility="{Binding running, Converter={StaticResource B2V}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- system health -->
                <TextBlock Text="System health" Style="{StaticResource SectionLabel}" />
                <UniformGrid x:Name="HealthGrid" Columns="3" />

                <!-- recent activity -->
                <TextBlock Text="Recent activity" Style="{StaticResource SectionLabel}" />
                <Border Style="{StaticResource Card}" Padding="6,4">
                    <Grid>
                        <TextBlock x:Name="NoActivity" Text="No recent activity." Style="{StaticResource Faint}" Margin="8,8" Visibility="Collapsed" />
                        <ItemsControl x:Name="ActivityList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="2,0,10,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource Amber}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DotState}" Value="ok"><Setter Property="Fill" Value="{DynamicResource Green}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding DotState}" Value="error"><Setter Property="Fill" Value="{DynamicResource Red}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Grid.Column="1" Text="{Binding Time}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource TextFaint}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding Kindly}" FontWeight="Medium" FontSize="12.5" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="3" Text="{Binding Last}" Style="{StaticResource Faint}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
