<Window x:Class="Hull.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hull" Height="690" Width="1060" MinWidth="860" MinHeight="540">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,14">
                <TextBlock DockPanel.Dock="Top" Text="Hull" Foreground="{StaticResource Accent}"
                           FontSize="20" FontWeight="Bold" Margin="6,0,0,16" />

                <Border DockPanel.Dock="Bottom" Style="{StaticResource Pill}"
                        HorizontalAlignment="Left" Margin="2,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="DaemonDot" Width="8" Height="8"
                                 Fill="{StaticResource TextFaint}" VerticalAlignment="Center" />
                        <TextBlock x:Name="DaemonText" Text="connecting…"
                                   Style="{StaticResource Muted}" Margin="7,0,0,0" />
                    </StackPanel>
                </Border>

                <ListBox x:Name="Nav" Style="{StaticResource PlainList}"
                         ItemContainerStyle="{StaticResource NavItem}"
                         SelectionChanged="OnNav" />
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl x:Name="ContentHost" Grid.Column="1" />
    </Grid>
</Window>
