<Window x:Class="Hull.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:Hull.Gui"
        Title="Hull" Height="700" Width="1124" MinWidth="900" MinHeight="560"
        WindowStyle="None" Background="{StaticResource BgApp}" UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="212" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="Transparent" Padding="16,16,16,12"
                        MouseLeftButtonDown="TitleBar_MouseDown">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="26" Height="26" CornerRadius="7" Background="{StaticResource Accent}">
                            <TextBlock Text="H" Foreground="{StaticResource TextOnAccent}" FontWeight="Bold"
                                       FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="hull" Foreground="{StaticResource Text}" FontSize="17" FontWeight="SemiBold"
                                   Margin="9,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Style="{StaticResource Pill}" Margin="12,12,12,14">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="DaemonDot" Width="8" Height="8" Fill="{StaticResource TextFaint}" VerticalAlignment="Center" />
                        <TextBlock x:Name="DaemonText" Text="connecting…" Style="{StaticResource Muted}" Margin="8,0,0,0" />
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,2">
                    <StackPanel x:Name="NavPanel" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Border x:Name="DragStrip" Background="Transparent" Height="48" VerticalAlignment="Top"
                    MouseLeftButtonDown="TitleBar_MouseDown" />
            <ContentControl x:Name="ContentHost" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0">
                <Button Style="{StaticResource WinBtn}" Click="OnMinimize">
                    <h:Icon Glyph="winmin" Width="16" Height="16" Brush="{StaticResource TextDim}" />
                </Button>
                <Button Style="{StaticResource WinBtn}" Click="OnMaximize">
                    <h:Icon Glyph="winmax" Width="13" Height="13" Brush="{StaticResource TextDim}" />
                </Button>
                <Button Style="{StaticResource WinClose}" Click="OnClose">
                    <h:Icon Glyph="x" Width="16" Height="16" Brush="{StaticResource Text}" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
