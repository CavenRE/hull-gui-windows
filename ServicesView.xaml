<UserControl x:Class="Hull.Gui.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="22,20">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Services" Style="{StaticResource ScreenTitle}" VerticalAlignment="Center" />
            <Button Content="Refresh" Style="{StaticResource Btn}" HorizontalAlignment="Right" Click="OnRefresh" />
        </Grid>

        <Grid>
        <TextBlock x:Name="EmptyMsg" Text="No shared services yet , add one with `hull services add`."
                   Style="{StaticResource Muted}" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed" />
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="List">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Top" Margin="0,6,12,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource TextFaint}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding running}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Green}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding name}" FontSize="15" FontWeight="SemiBold" />
                                        <Border Style="{StaticResource Pill}" Background="{StaticResource AccentSoft}"
                                                BorderThickness="0" Padding="7,2" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding engine}" Foreground="{StaticResource Accent}" FontSize="11" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Endpoint}" FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource TextDim}" Margin="0,5,0,0" />
                                    <TextBlock Text="{Binding Linked}" Style="{StaticResource Faint}" Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="Start" Style="{StaticResource Btn}" Height="26" FontSize="12" Click="OnStart" />
                                    <Button Content="Stop" Style="{StaticResource Btn}" Height="26" FontSize="12" Margin="6,0,0,0" Click="OnStop" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
