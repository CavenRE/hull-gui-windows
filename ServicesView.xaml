<UserControl x:Class="Hull.Gui.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:Hull.Gui">
    <DockPanel Margin="24,14,24,20">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18" Height="34">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Services" Style="{StaticResource ScreenTitle}" />
                <TextBlock x:Name="Sub" Style="{StaticResource Muted}" Margin="14,9,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <Button Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" Margin="0,0,112,0"
                    VerticalAlignment="Center" Click="OnAdd">
                <StackPanel Orientation="Horizontal">
                    <h:Icon Glyph="plus" Width="13" Height="13" Brush="{StaticResource TextOnAccent}" VerticalAlignment="Center" />
                    <TextBlock Text="Add instance" Margin="7,0,0,0" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid>
            <TextBlock x:Name="EmptyMsg" Text="No shared services yet , add one with `hull services add`."
                       Style="{StaticResource Muted}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="List">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,12,12" VerticalAlignment="Top">
                                <StackPanel>
                                    <!-- header -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <h:Icon Grid.Column="0" Glyph="{Binding Glyph}" Width="18" Height="18"
                                                Brush="{StaticResource TextDim}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding name}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                            <Border Style="{StaticResource Chip}" Background="{StaticResource AccentSoft}"
                                                    BorderThickness="0" Margin="9,0,0,0">
                                                <TextBlock Text="{Binding Badge}" Foreground="{StaticResource Accent}" FontSize="11" />
                                            </Border>
                                        </StackPanel>
                                        <Ellipse Grid.Column="2" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource TextFaint}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding running}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource Green}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Button Grid.Column="3" Style="{StaticResource Btn}" Height="26" FontSize="12"
                                                Content="Start" Click="OnStart" Visibility="{Binding NotRunning, Converter={StaticResource B2V}}" />
                                        <Button Grid.Column="3" Style="{StaticResource Btn}" Height="26" FontSize="12"
                                                Content="Stop" Click="OnStop" Visibility="{Binding running, Converter={StaticResource B2V}}" />
                                    </Grid>

                                    <TextBlock Margin="28,8,0,0" Visibility="{Binding HasUrl, Converter={StaticResource B2V}}">
                                        <Hyperlink Click="OnOpenUrl" Foreground="{StaticResource Accent}" TextDecorations="None">
                                            <Run Text="{Binding url, Mode=OneWay}" />
                                        </Hyperlink>
                                    </TextBlock>

                                    <!-- connection details -->
                                    <Border Background="{StaticResource BgInset}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="7" Margin="0,10,0,0"
                                            Visibility="{Binding HasPort, Converter={StaticResource B2V}}">
                                        <StackPanel>
                                            <Grid Margin="11,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="host" Style="{StaticResource Muted}" />
                                                <TextBlock Grid.Column="1" Text="{Binding HostText}" FontFamily="Consolas" FontSize="12" />
                                                <Button Grid.Column="2" Style="{StaticResource IconBtn}" Padding="4" Tag="{Binding HostText}" Click="OnCopy">
                                                    <h:Icon Glyph="copy" Width="13" Height="13" Brush="{StaticResource TextFaint}" />
                                                </Button>
                                            </Grid>
                                            <Border Height="1" Background="{StaticResource Border}" />
                                            <Grid Margin="11,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="port" Style="{StaticResource Muted}" />
                                                <TextBlock Grid.Column="1" Text="{Binding PortText}" FontFamily="Consolas" FontSize="12" />
                                                <Button Grid.Column="2" Style="{StaticResource IconBtn}" Padding="4" Tag="{Binding PortText}" Click="OnCopy">
                                                    <h:Icon Glyph="copy" Width="13" Height="13" Brush="{StaticResource TextFaint}" />
                                                </Button>
                                            </Grid>
                                            <Border Height="1" Background="{StaticResource Border}" />
                                            <Grid Margin="11,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="user" Style="{StaticResource Muted}" />
                                                <TextBlock Grid.Column="1" Text="{Binding UserText}" FontFamily="Consolas" FontSize="12" />
                                                <Button Grid.Column="2" Style="{StaticResource IconBtn}" Padding="4" Tag="{Binding UserText}" Click="OnCopy">
                                                    <h:Icon Glyph="copy" Width="13" Height="13" Brush="{StaticResource TextFaint}" />
                                                </Button>
                                            </Grid>
                                            <Border Height="1" Background="{StaticResource Border}" />
                                            <Grid Margin="11,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" /><ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="password" Style="{StaticResource Muted}" />
                                                <TextBlock Grid.Column="1" Text="(no password)" Foreground="{StaticResource TextFaint}"
                                                           FontStyle="Italic" FontSize="12" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding Linked}" Style="{StaticResource Faint}" Margin="2,10,0,0"
                                               Visibility="{Binding HasLinked, Converter={StaticResource B2V}}" />
                                    <TextBlock Text="No linked projects" Style="{StaticResource Faint}" Margin="2,10,0,0"
                                               Visibility="{Binding NoLinked, Converter={StaticResource B2V}}" />

                                    <!-- footer -->
                                    <Grid Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource Btn}" Height="26" FontSize="12" Content="Open with…" Click="OnOpenWith" />
                                            <Button Style="{StaticResource Btn}" Height="26" FontSize="12" Content="Link a project" Margin="6,0,0,0" Click="OnLink" />
                                        </StackPanel>
                                        <Button Style="{StaticResource BtnDanger}" HorizontalAlignment="Right" Height="26" FontSize="12"
                                                Content="Destroy" Click="OnDestroy" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
