<!-- Dark palette (design/tokens.css). Swapped at runtime by ThemeManager;
     every brush key here has a twin in Palette.Light.xaml. Styles reference
     these via DynamicResource so a swap updates the live UI. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgApp"        Color="#242423" />
    <SolidColorBrush x:Key="BgPanel"      Color="#2A2B28" />
    <SolidColorBrush x:Key="BgCard"       Color="#333533" />
    <SolidColorBrush x:Key="BgCard2"      Color="#3C3E3A" />
    <SolidColorBrush x:Key="BgInset"      Color="#1D1E1C" />
    <SolidColorBrush x:Key="Border"       Color="#22E8EDDF" />
    <SolidColorBrush x:Key="BorderStrong" Color="#2EE8EDDF" />
    <SolidColorBrush x:Key="Text"         Color="#E8EDDF" />
    <SolidColorBrush x:Key="TextDim"      Color="#B3B9AC" />
    <SolidColorBrush x:Key="TextFaint"    Color="#7E8377" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#242423" />
    <SolidColorBrush x:Key="Accent"       Color="#F5CB5C" />
    <SolidColorBrush x:Key="AccentHover"  Color="#F8D572" />
    <SolidColorBrush x:Key="AccentPress"  Color="#E6B942" />
    <SolidColorBrush x:Key="AccentSoft"   Color="#29F5CB5C" />
    <SolidColorBrush x:Key="Green"        Color="#7FB069" />
    <SolidColorBrush x:Key="Amber"        Color="#E08A3C" />
    <SolidColorBrush x:Key="Red"          Color="#E0685F" />
    <SolidColorBrush x:Key="RedSoft"      Color="#29E0685F" />
    <SolidColorBrush x:Key="Ctrl"         Color="#3A3C38" />
    <SolidColorBrush x:Key="CtrlHover"    Color="#45473F" />
    <SolidColorBrush x:Key="CtrlBorder"   Color="#21E8EDDF" />
    <SolidColorBrush x:Key="Scrim"        Color="#99000000" />
</ResourceDictionary>
