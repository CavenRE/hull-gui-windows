<UserControl x:Class="Hull.Gui.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:Hull.Gui">
    <Grid Background="{DynamicResource BgApp}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- rail -->
        <Border Grid.Column="0" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
            <DockPanel Margin="26,32,26,26">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,32">
                    <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource Accent}">
                        <TextBlock Text="H" Foreground="{DynamicResource TextOnAccent}" FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="hull" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="Bold" Margin="11,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="Local-first development.&#x0a;No accounts, no cloud — everything runs on your machine."
                           Foreground="{DynamicResource TextFaint}" FontSize="12" TextWrapping="Wrap" />
                <StackPanel x:Name="Steps" />
            </DockPanel>
        </Border>

        <!-- main -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Height="46" />
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="56,16">
                <Grid x:Name="Foot" />
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="56,8,56,24">
                <StackPanel x:Name="Pane" MaxWidth="560" HorizontalAlignment="Left" />
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
