<UserControl x:Class="Hull.Gui.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="TitleText" Style="{StaticResource ScreenTitle}" HorizontalAlignment="Center" />
        <TextBlock x:Name="BodyText" Style="{StaticResource Muted}" Margin="0,8,0,0" HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
