<UserControl x:Class="Hull.Gui.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="22,20">
        <TextBlock DockPanel.Dock="Top" Text="Settings" Style="{StaticResource ScreenTitle}" Margin="0,0,0,16" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- General -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="GENERAL" Style="{StaticResource CardTitle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Local TLD" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                                <TextBox x:Name="TldBox" Style="{StaticResource Input}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="Editor command" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                                <TextBox x:Name="EditorBox" Style="{StaticResource Input}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="DB tool" Style="{StaticResource Muted}" Margin="0,0,0,6" />
                                <TextBox x:Name="DbToolBox" Style="{StaticResource Input}" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Save" Style="{StaticResource BtnPrimary}" Click="OnSave" />
                            <TextBlock x:Name="SaveStatus" Style="{StaticResource Faint}" VerticalAlignment="Center" Margin="12,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Project roots -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="PROJECT FOLDERS" Style="{StaticResource CardTitle}" />
                        <ItemsControl x:Name="RootsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                               Foreground="{StaticResource TextDim}" Margin="0,3" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Health -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="DOCTOR" Style="{StaticResource CardTitle}" />
                        <ItemsControl x:Name="DoctorList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource Green}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding status}" Value="warn">
                                                            <Setter Property="Fill" Value="{StaticResource Amber}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding status}" Value="fail">
                                                            <Setter Property="Fill" Value="{StaticResource Red}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Grid.Column="1" Text="{Binding name}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding detail}" Style="{StaticResource Faint}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Danger / daemon -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DAEMON" Style="{StaticResource CardTitle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Stop All" Style="{StaticResource Btn}" Click="OnStopAll" />
                            <Button Content="Stop Daemon" Style="{StaticResource BtnDanger}" Margin="8,0,0,0" Click="OnStopDaemon" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
