<!-- Light palette (design/screenshots/settings-light.jpg, services-list.jpg):
     warm sage backgrounds, near-white cards, dark Shadow-Grey text, same
     Tuscan-Sun accent. Mirrors every key in Palette.Dark.xaml. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgApp"        Color="#E5EADD" />
    <SolidColorBrush x:Key="BgPanel"      Color="#EDF1E7" />
    <SolidColorBrush x:Key="BgCard"       Color="#FBFCF9" />
    <SolidColorBrush x:Key="BgCard2"      Color="#F1F4EC" />
    <SolidColorBrush x:Key="BgInset"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="Border"       Color="#1F242423" />
    <SolidColorBrush x:Key="BorderStrong" Color="#33242423" />
    <SolidColorBrush x:Key="Text"         Color="#242423" />
    <SolidColorBrush x:Key="TextDim"      Color="#585C51" />
    <SolidColorBrush x:Key="TextFaint"    Color="#8A8E81" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#242423" />
    <SolidColorBrush x:Key="Accent"       Color="#F5CB5C" />
    <SolidColorBrush x:Key="AccentHover"  Color="#EFC149" />
    <SolidColorBrush x:Key="AccentPress"  Color="#E0B43C" />
    <SolidColorBrush x:Key="AccentSoft"   Color="#33F5CB5C" />
    <SolidColorBrush x:Key="Green"        Color="#5E9447" />
    <SolidColorBrush x:Key="Amber"        Color="#C2762A" />
    <SolidColorBrush x:Key="Red"          Color="#C9534A" />
    <SolidColorBrush x:Key="RedSoft"      Color="#1FC9534A" />
    <SolidColorBrush x:Key="Ctrl"         Color="#FFFFFF" />
    <SolidColorBrush x:Key="CtrlHover"    Color="#ECEFE6" />
    <SolidColorBrush x:Key="CtrlBorder"   Color="#22242423" />
    <SolidColorBrush x:Key="Scrim"        Color="#55000000" />
</ResourceDictionary>
