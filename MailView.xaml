<UserControl x:Class="Hull.Gui.MailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Mail" Style="{StaticResource ScreenTitle}" Margin="24,20,24,8" />
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,28">
            <StackPanel x:Name="Body" />
        </ScrollViewer>
    </Grid>
</UserControl>
