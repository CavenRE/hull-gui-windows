<UserControl x:Class="Hull.Gui.NewProjectDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Width="468" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderStrong}"
            BorderThickness="1" CornerRadius="10">
        <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="18,15">
                <TextBlock Text="New project" FontSize="14" FontWeight="SemiBold" />
            </Border>
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="18,14">
                <Grid>
                    <TextBlock x:Name="Status" Style="{StaticResource Faint}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Btn}" Content="Cancel" Click="OnCancel" />
                        <Button Style="{StaticResource BtnPrimary}" Content="Create" Margin="8,0,0,0" Click="OnCreate" />
                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel x:Name="Body" Margin="18,16" />
        </DockPanel>
    </Border>
</UserControl>
