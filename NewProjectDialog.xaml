<UserControl x:Class="Hull.Gui.NewProjectDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Width="560" MaxHeight="660" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderStrong}"
            BorderThickness="1" CornerRadius="10">
        <DockPanel>
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
                <TextBlock Text="New project" FontSize="15" FontWeight="SemiBold" />
            </Border>
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="20,14">
                <Grid>
                    <TextBlock x:Name="Status" Style="{StaticResource Faint}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Btn}" Content="Cancel" Click="OnCancel" />
                        <Button x:Name="CreateBtn" Style="{StaticResource BtnPrimary}" Content="Create project" Margin="8,0,0,0" Click="OnCreate" />
                    </StackPanel>
                </Grid>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
                <StackPanel x:Name="Body" Margin="20,16" />
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
